VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# EmailJS (correo de bienvenida + pase) - https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID_WELCOME=
# Plantilla del email que recibe el invitado con el link a su pase, si dejó su
# email al autoregistrarse en /events/:id/join. Vars: to_email, event_name, pass_url.
# Sin esta variable, sendGuestPassEmail no hace nada (no rompe el registro).
VITE_EMAILJS_TEMPLATE_ID_PASS=
# NOTA: el plan gratis de EmailJS limita a 2 templates (WELCOME + PASS ya las
# ocupan). Por eso lo siguiente queda deshabilitado hasta ampliar el plan o
# liberar un slot:
#
# Aviso al admin cuando alguien reporta un comentario o foto del muro. Vars:
# to_email, event_name, reported_at, reported_user, reporter, content_type,
# reason, admin_url. Sin esta variable (o sin VITE_REPORT_ADMIN_EMAIL), el
# reporte se guarda igual — solo no se envía el correo de aviso inmediato.
# PENDIENTE por el mismo límite de 2 templates (ver nota arriba).
VITE_EMAILJS_TEMPLATE_ID_REPORT=
VITE_REPORT_ADMIN_EMAIL=ericmunoz441@gmail.com
VITE_EMAILJS_PUBLIC_KEY=

# Cloudinary (foto de perfil) - https://cloudinary.com/
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# App Check / anti-bot (opcional) - clave reCAPTCHA v3 desde
# https://www.google.com/recaptcha/admin (tipo "v3"). Sin esta variable la app
# funciona igual, simplemente sin protección anti-bot en los formularios públicos.
# Después de configurarla, activar "Enforce" en Firebase Console > App Check > Firestore.
VITE_RECAPTCHA_SITE_KEY=

# Sentry (error monitoring + performance + session replay) - https://sentry.io
# Crear un proyecto tipo "React", plan Developer (gratis). Sin VITE_SENTRY_DSN
# la app funciona igual, simplemente sin reportar nada a Sentry (initSentry()
# no hace nada). El DSN es público por diseño (como el resto de la config de
# Firebase/Cloudinary de arriba) — lo que protege la cuenta es el dashboard,
# no que el valor esté oculto.
VITE_SENTRY_DSN=
# Estas 3 NO llevan prefijo VITE_ a propósito: solo las usa el plugin de Vite
# en build-time (para subir source maps y crear el release), nunca llegan al
# bundle del navegador. Se generan en Sentry > Settings > Auth Tokens (scope
# "project:releases") y Settings > General del org/proyecto.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
