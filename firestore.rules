rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(eventId) {
      return request.auth != null &&
        request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.ownerId;
    }

    function isCoOrganizer(eventId) {
      let ev = get(/databases/$(database)/documents/events/$(eventId));
      return request.auth != null &&
        ev.data.coOrganizersMap != null &&
        request.auth.uid in ev.data.coOrganizersMap;
    }

    function isOwnerOrCoOrg(eventId) {
      return isOwner(eventId) || isCoOrganizer(eventId);
    }

    // Permiso granular de un co-organizador (ver src/types/coOrganizerPermissions.ts).
    // `def` es el default LEGACY para ese permiso — debe coincidir con
    // LEGACY_COORG_DEFAULTS en ese archivo, así un co-organizador agregado
    // antes de que existiera coOrganizerPermissions (o antes de que existiera
    // este permiso puntual) conserva el mismo acceso amplio que ya tenía.
    function coOrgPerm(eventId, key, def) {
      let ev = get(/databases/$(database)/documents/events/$(eventId));
      return ev.data.get('coOrganizerPermissions', {}).get(request.auth.uid, {}).get(key, def);
    }

    // El dueño siempre puede; un co-organizador puede si tiene ese permiso
    // (o no tiene entrada en coOrganizerPermissions y `def` es true). Único
    // punto de la app que decide "¿puede este usuario hacer X en este
    // evento?" — cada `allow` de acá abajo llama a esto en vez de reimplementar
    // la misma comparación.
    function canDo(eventId, key, def) {
      return isOwner(eventId) || (isCoOrganizer(eventId) && coOrgPerm(eventId, key, def));
    }

    // Variantes de isOwner/isCoOrganizer/coOrgPerm/canDo para usar SOLO
    // dentro de `match /events/{eventId}` (su `allow update`/`allow
    // delete`) — ahí `resource.data` YA ES el documento del evento, así que
    // llamar a isOwner(eventId)/canDo(eventId,...) reevalúa un get() al
    // MISMO documento que la regla ya tiene servido sin costo. Con varias
    // ramas en esa única regla `allow update` (cada una llamando canDo, que
    // a su vez llama isOwner+isCoOrganizer+coOrgPerm, cada una con su propio
    // get()), el evaluador de reglas llegó a rechazar escrituras totalmente
    // ajenas a coanfitriones (ej. el autoregistro público) con "maximum of
    // 1000 expressions to evaluate" — no por exceso de LECTURAS (Firestore
    // cachea los get() al mismo path dentro de una misma evaluación) sino
    // por exceso de EVALUACIONES DE EXPRESIÓN de la regla entera. Estas
    // variantes leen directo de `evData` (ya en mano) en vez de volver a
    // pedir el documento — mismo resultado, sin la llamada a get() extra.
    function isOwnerData(evData) {
      return request.auth != null && request.auth.uid == evData.ownerId;
    }

    function isCoOrganizerData(evData) {
      return request.auth != null &&
        evData.coOrganizersMap != null &&
        request.auth.uid in evData.coOrganizersMap;
    }

    function coOrgPermData(evData, key, def) {
      return evData.get('coOrganizerPermissions', {}).get(request.auth.uid, {}).get(key, def);
    }

    function canDoData(evData, key, def) {
      return isOwnerData(evData) || (isCoOrganizerData(evData) && coOrgPermData(evData, key, def));
    }

    // Para usar canDoData/companionsWithinLimitData FUERA de
    // `match /events/{eventId}` (ej. dentro de `match /guests/{guestId}`,
    // donde no hay un `resource.data` de evento gratis) sin repetir el path
    // completo del get() en cada call site. Nota: Firestore Rules no permite
    // `let` a nivel de match block (solo dentro de funciones), así que esto
    // sigue siendo un get() por cada llamada — pero UNO solo (cacheado por
    // path), en vez de los 3 get()s encadenados que dispara canDo() vía
    // isOwner+isCoOrganizer+coOrgPerm.
    function eventDataFor(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    // Admin = tener un documento propio en /admins/{uid}. Se eligió esta
    // colección en vez de customClaims (Fase 4D) porque asignar customClaims
    // requiere el Admin SDK, que en este proyecto solo está disponible vía
    // Cloud Functions — y este proyecto está deliberadamente en el plan
    // Spark (gratis), sin Blaze. Agregar/quitar admins se hace a mano desde
    // la consola de Firebase (Firestore → admins), nunca desde la app: ver
    // `allow write: if false` en el match de abajo.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOpenEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data.entryMode in ['open', 'hybrid'];
    }

    // Evita crear un evento con `requiresPayment: true` y precio 0/ausente —
    // el cliente ya bloquea esto antes de enviar (ver EventCreate.tsx/
    // canProceedStep y EditEventForm.tsx/handleReviewSubmit), esta es la
    // barrera real si alguien habla directo contra Firestore. Solo se aplica
    // en `create`: en `update` el dueño ya tiene control total sobre su
    // propio evento (ver `allow update` más abajo) y la misma pantalla de
    // edición pasa por el mismo guard cliente.
    function isValidEventPricing() {
      let d = request.resource.data;
      return !d.requiresPayment || (d.ticketPrice is number && d.ticketPrice > 0);
    }

    // EventData.maxCompanions (StepInvitationMethod/EditEventForm): tope de
    // acompañantes por invitado individual, 0-20 — debe coincidir con
    // GUEST_MAX_COMPANIONS en src/utils/validation.ts. Mismo criterio que
    // isValidEventPricing: solo se valida en `create`, en `update` el dueño
    // ya tiene control total sobre su propio evento.
    function isValidMaxCompanions() {
      let d = request.resource.data;
      return !('maxCompanions' in d)
        || (d.maxCompanions is number && d.maxCompanions >= 0 && d.maxCompanions <= 20);
    }

    // Techo de cantidad para 3 arrays/mapas del evento que antes no tenían
    // ningún límite server-side (solo disciplina del organizador): definían
    // un riesgo de documento gigante sin barrera real, ya que un cliente que
    // hable directo contra Firestore podía ignorar por completo los límites
    // de UI (TimelineEditor/CustomFieldsBuilder/useCoOrganizers). Debe
    // coincidir con EVENT_CUSTOM_FIELDS_MAX_COUNT/EVENT_TIMELINE_MAX_ENTRIES/
    // EVENT_CO_ORGANIZERS_MAX en src/utils/validation.ts. Se evalúa sobre el
    // documento resultante completo (no un delta), así que una escritura que
    // no toca estos campos sigue pasando trivialmente (quedan como estaban).
    function eventContentCapsOk() {
      let d = request.resource.data;
      return d.get('customFields', []).size() <= 30
        && d.get('timeline', []).size() <= 20
        && d.get('coOrganizersMap', {}).size() <= 20;
    }

    // Valida el delta de un contador de "gente adentro" (checkedInCount /
    // occupancyCount): sin cambios, o +-1..50 en cualquier dirección —
    // walkIn/walkOut mueven de a 1 (Opción A/C, sin acompañantes), mientras
    // que checkInGuest/checkOutGuest mueven partySize() (invitado +
    // acompañantes) de una sola vez, en cualquiera de los dos sentidos según
    // sea una entrada o una salida. El tope de 50 no se ata a un límite
    // exacto de acompañantes que la UI no impone.
    function counterDeltaOk(newVal, oldVal) {
      return newVal == oldVal
        || (newVal < oldVal && newVal >= oldVal - 50)
        || (newVal > oldVal && newVal <= oldVal + 50);
    }

    // Cualquier cliente puede crear mensajes del muro sin autenticarse —
    // estos límites son la última barrera real si alguien evita por completo
    // la capa de aplicación (src/firebase/wall.ts) y escribe directo contra
    // Firestore. Deben coincidir con src/utils/validation.ts.
    // authorRole/postWall: antes `authorRole` no se validaba en absoluto acá
    // (isValidWallReply sí lo restringía a ['owner','guest'], pero un mensaje
    // NUEVO no) — el cliente decide localmente si postea como 'owner'
    // (EventWall.tsx compara uid contra event.ownerId), sin nada del lado
    // servidor que lo confirme. Cualquiera hablando directo contra Firestore
    // podía postear como 'owner' y suplantar al organizador. `postWall`
    // (permiso de coanfitrión, ver src/types/coOrganizerPermissions.ts)
    // tampoco se aplicaba en ningún lado — el toggle del editor no tenía
    // efecto real. Solo alcanza a coanfitriones: el dueño nunca está en
    // coOrganizersMap (isCoOrganizer da false) y un invitado sin sesión
    // tampoco (requiere request.auth).
    function isValidWallMessage(eventId) {
      let d = request.resource.data;
      return d.text is string && d.text.size() > 0 && d.text.size() <= 500
        && d.type in ['comment', 'question', 'music', 'idea']
        && d.authorName is string && d.authorName.size() > 0 && d.authorName.size() <= 60
        && d.authorToken is string && d.authorToken.size() <= 100
        && d.authorRole in ['owner', 'guest']
        && (d.authorRole == 'guest' || isOwner(eventId))
        && (!isCoOrganizer(eventId) || coOrgPerm(eventId, 'postWall', true));
    }

    // Misma validación que isValidWallMessage, para el elemento agregado al
    // array `replies` (ver isValidWallReplyAppend más abajo). authorRole no
    // se restringe a 'guest' — el anfitrión responde con este mismo flujo,
    // no uno aparte.
    function isValidWallReply(r, eventId) {
      return r.text is string && r.text.size() > 0 && r.text.size() <= 500
        && r.authorName is string && r.authorName.size() > 0 && r.authorName.size() <= 60
        && r.authorToken is string && r.authorToken.size() <= 100
        && r.authorRole in ['owner', 'guest']
        // Mismo chequeo de suplantación que isValidWallMessage: solo el
        // dueño real puede quedar marcado 'owner' en su propia respuesta.
        && (r.authorRole == 'guest' || isOwner(eventId));
    }

    // Cualquier participante autorizado del muro puede agregar una respuesta
    // (misma autorización que crear un mensaje nuevo: no bloqueado por
    // sanción). Solo permite AGREGAR un elemento al final del array —
    // request.resource.data.replies[0:N] == resource.data.replies exige que
    // las respuestas ya existentes lleguen sin tocar, para que un cliente no
    // pueda reescribir o borrar respuestas ajenas aprovechando este permiso.
    //
    // Reutilizada también por `photos` (ver match /photos/{photoId} más
    // abajo) — responder a una foto o a una "historia" (que es la misma foto
    // vista agrupada, ver StoriesBar.tsx) pasa por esta misma función, sin
    // duplicar su lógica. oldReplies tolera un documento sin el campo
    // `replies` (fotos subidas antes de esta función, que nunca lo
    // escribieron) tratándolo como lista vacía — así no hace falta
    // backfillear ninguna foto ya existente para que pueda recibir su
    // primera respuesta.
    function isValidWallReplyAppend(eventId) {
      let oldReplies = resource.data.get('replies', []);
      let newReplies = request.resource.data.replies;
      return (request.auth == null || !commentsBlocked(eventId))
        && newReplies.size() == oldReplies.size() + 1
        && newReplies.size() <= 500
        // oldReplies.size() == 0 evita el slice newReplies[0:0]: sin
        // respuestas previas no hay nada que preservar, y ese slice vacío
        // dispara un error de evaluación del motor de reglas (visto en el
        // emulador al probar la primera respuesta de una foto legacy sin
        // `replies`, ver isValidWallReplyAppend arriba) en vez de devolver
        // limpiamente una lista vacía.
        && (oldReplies.size() == 0 || newReplies[0:oldReplies.size()] == oldReplies)
        && isValidWallReply(newReplies[oldReplies.size()], eventId);
    }

    // Evita que UNA sola escritura reemplace `reactions` agregando/quitando
    // más de una clave a la vez — el cliente real (reactToContent, ver
    // src/firebase/interactions.ts) siempre toca una sola clave por
    // escritura vía FieldPath. Las reacciones son anónimas (identificadas
    // por un token de dispositivo en localStorage, no por request.auth.uid
    // — ni siquiera para un usuario con sesión, ver EventWall.tsx), así que
    // no hay forma de verificar del lado servidor que la key corresponda a
    // una identidad real; este chequeo no cierra ESE gap (documentado, sin
    // solución posible sin cambiar el modelo de reacciones a algo atado a
    // auth). Lo que sí evita es el vector más barato para inflar el mapa
    // hasta el tope de tamaño (ver 5000 más abajo): antes, UN solo request
    // directo contra Firestore podía saltar de 10 reacciones a 5000 de
    // golpe; ahora un abuso necesita 5000 requests separados, mucho más
    // lento y detectable por los límites de tasa de Firestore/App Check.
    function isSingleReactionKeyChange(oldReactions, newReactions) {
      return newReactions.diff(oldReactions).affectedKeys().size() == 1;
    }

    // Auto-registro público de invitados (registerWalkInGuest, eventos
    // open/hybrid). Solo se valida esta rama pública — el alta hecha por el
    // organizador (addGuest/addGuestsBulk) no pasa por isOpenEvent y queda
    // fuera de esta validación, sin cambiar su comportamiento actual.
    // customData.size() limita la CANTIDAD de campos (Firestore rules no
    // puede iterar un mapa para validar el largo de cada valor individual —
    // eso solo lo cubren la UI y src/firebase/capacity.ts). Límites deben
    // coincidir con src/utils/validation.ts.
    //
    // Los campos de estado (status/rsvpStatus/checkedInAt/paymentStatus/
    // holdExpiresAt/paymentMethod) se pinean a los valores exactos que
    // escribe registerWalkInGuest: sin esto, un cliente que hable directo
    // contra Firestore (evitando src/firebase/capacity.ts) podía crearse a
    // sí mismo ya 'checked_in' o 'paid' en el mismo request de alta pública,
    // saltándose por completo el gate de pago del check-in y el cobro real.
    //
    // Ya no existe el "apartado temporal de lugar" (cronómetro/vencimiento):
    // el registro nunca se bloquea por cupo y el invitado puede subir su
    // comprobante cuando quiera, sin plazo. holdExpiresAt siempre debe
    // llegar en null — se sigue exigiendo el campo (no se omite) para que
    // este chequeo no dependa de leer una clave ausente (que Firestore
    // Rules trata como error, no como null). Queda como defensa en
    // profundidad: nadie, ni hablando directo contra Firestore, puede
    // fabricarse un cronómetro que ya no existe en la app.
    function isValidPublicGuestRegistration(eventId) {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 121
        && (!('customData' in d) || (d.customData is map && d.customData.size() <= 30))
        && (!('paymentNote' in d) || (d.paymentNote is string && d.paymentNote.size() <= 300))
        && d.status == 'invited'
        && d.rsvpStatus == 'yes'
        && d.checkedInAt == null
        && d.paymentStatus == 'unpaid'
        && d.paymentMethod in [null, 'transfer', 'cash']
        && d.holdExpiresAt == null
        && companionsWithinLimit(eventId, d, false)
        && (
          // guestUid/guestPhotoURL: src/firebase/capacity.ts los escribe SIEMPRE
          // en el auto-registro (null si no hay sesión). Sin esta validación, un
          // cliente que hable directo contra Firestore podría adjudicarse el uid
          // de otra persona (apareciendo en el dashboard del organizador como si
          // esa cuenta ajena se hubiera autoregistrado) o mandar cualquier URL
          // arbitraria como foto. Defensa: guestUid debe ser el uid autenticado
          // del propio request, y guestPhotoURL (si viene) debe coincidir con el
          // photoURL que ESE usuario ya tiene en su propio perfil — nunca inventado.
          //
          // guestUid/guestPhotoURL en null se acepta CON o SIN sesión (antes la
          // primera rama exigía request.auth == null): null no reclama ninguna
          // identidad ni publica ninguna URL, así que no hay nada que suplantar.
          // Exigir sesión nula acá rompía el registro real: si el listener de
          // perfil (useAuth) todavía no había emitido cuando el usuario envió el
          // formulario, EventJoin mandaba null teniendo el request una sesión
          // activa, y el registro entero moría con permission-denied.
          (d.guestUid == null && d.guestPhotoURL == null)
          || (
            request.auth != null
            && d.guestUid == request.auth.uid
            && (
              // Registrarse sin foto siempre es válido, aunque el perfil sí
              // tenga una (perfil aún no cargado en el cliente, o usuario de
              // Google sin documento users/{uid} — en ambos casos el get() de
              // abajo denegaría un registro legítimo). El corto-circuito además
              // evita ese get() cuando no hay foto que verificar.
              d.guestPhotoURL == null
              // .data.get('photoURL', null), no .data.photoURL: leer una clave
              // ausente de un mapa en reglas de Firestore lanza error, no null —
              // un usuario sin foto debe poder autoregistrarse igual.
              || d.guestPhotoURL == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('photoURL', null)
            )
          )
        );
    }

    // Contadores del EVENTO tolerantes a documentos legacy: eventos creados
    // antes de que existieran estos campos no los tienen, y en reglas de
    // Firestore leer una clave ausente (resource.data.peopleCount) es un
    // ERROR que deniega la escritura entera — era la causa del
    // "Missing or insufficient permissions" del autoregistro público sobre
    // eventos viejos. El fallback de peopleCount a guestCount replica el
    // mismo criterio que ya usan la lectura (getEvent, src/firebase/events.ts)
    // y la escritura (registerWalkInGuest, src/firebase/capacity.ts, que
    // backfillea el campo con este mismo valor).
    function eventGuestCountBefore(evData) {
      return evData.get('guestCount', 0);
    }

    function eventPeopleCountBefore(evData) {
      return evData.get('peopleCount', eventGuestCountBefore(evData));
    }

    function isValidPublicGuestContact() {
      let d = request.resource.data;
      return (!('email' in d) || (d.email is string && d.email.size() <= 120))
        && (!('phone' in d) || (d.phone is string && d.phone.size() <= 30));
    }

    // Tamaño de `companions` de un documento dado (`d`), sea cual sea su
    // representación actual: array (organizador, o cualquier invitado que ya
    // haya editado su información una vez) o número legado (autoregistro
    // público vía registerWalkInGuest/capacity.ts, que nunca escribe un
    // array — ver normalizeCompanions() en src/firebase/guests.ts, misma
    // traducción del lado cliente). Reutilizada tanto para el doc VIEJO
    // (resource.data, ver companionsCountBefore) como para el NUEVO
    // (request.resource.data, ver companionsWithinLimit).
    function companionsCountOf(d) {
      return d.companions is list
        ? d.companions.size()
        : (d.companions is number ? d.companions : 0);
    }

    // Tamaño de `companions` ANTES de esta escritura. Sin esto,
    // resource.data.companions.size() lanzaría un error de tipo para todo
    // invitado autoregistrado en un evento open/hybrid, bloqueando el
    // self-edit justo para el público que más lo necesita.
    function companionsCountBefore() {
      return companionsCountOf(resource.data);
    }

    // Tope de acompañantes configurado por el organizador para este evento
    // (EventData.maxCompanions). El default 9 aplica SOLO al campo ausente
    // (evento anterior a v1.35.0): esos eventos siempre permitieron grupos de
    // hasta 10 personas en el autoregistro, y el default 0 anterior les quitó
    // los acompañantes en silencio. Un evento nuevo siempre escribe el campo
    // (0 si el organizador no lo toca), así que el 0 explícito sigue
    // significando "sin acompañantes". Debe coincidir con
    // GUEST_LEGACY_MAX_COMPANIONS en src/utils/validation.ts
    // (resolveMaxCompanions aplica el mismo default del lado cliente). NO
    // aplica a invitados `isGroup: true` ("familia o grupo"), que sigue
    // gobernado por su propio tope GUEST_GROUP_MAX_MEMBERS (solo en el
    // cliente, es una herramienta de alta masiva ya confiada al organizador).
    function eventMaxCompanions(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data.get('maxCompanions', 9);
    }

    // `d` es el documento NUEVO (request.resource.data) que se está
    // creando/actualizando. `allowGrandfathered` (literal true/false en cada
    // call site, nunca una expresión que dependa de `resource`) habilita
    // tolerar un valor por ENCIMA del límite si no lo está AUMENTANDO
    // respecto del documento viejo — así un invitado cargado antes de
    // configurar este límite (o antes de que existiera el campo) se puede
    // seguir editando/guardando sin recortarlo a la fuerza; solo se bloquea
    // sumar más acompañantes por encima del tope. En `create` no hay
    // documento viejo, así que ese caso siempre pasa `false`.
    function companionsWithinLimit(eventId, d, allowGrandfathered) {
      return d.get('isGroup', false) == true
        || companionsCountOf(d) <= eventMaxCompanions(eventId)
        || (allowGrandfathered && companionsCountOf(d) <= companionsCountBefore());
    }

    // Variante de companionsWithinLimit que recibe `evData` ya cargado en vez
    // de volver a pedir el documento del evento — mismo motivo que
    // isOwnerData/canDoData más arriba. Usada en guests/{guestId} (ver
    // `allow update`), donde SÍ hace falta un `get()` al evento (a diferencia
    // de `events/{eventId}`, que ya tiene su propio documento como
    // resource.data) pero solo UNA vez para toda la regla, no una vez por
    // cada rama que lo necesite.
    function companionsWithinLimitData(evData, d, allowGrandfathered) {
      return d.get('isGroup', false) == true
        || companionsCountOf(d) <= evData.get('maxCompanions', 9)
        || (allowGrandfathered && companionsCountOf(d) <= companionsCountBefore());
    }

    // Auto-edición del propio invitado desde su pase (GuestPass, "Editar mis
    // datos"). NO permite variar la CANTIDAD de acompañantes — solo sus
    // datos (ver companionsCountBefore). Límites deben coincidir con
    // GUEST_NAME_PART_MAX/GUEST_CUSTOM_FIELD_MAX_COUNT en
    // src/utils/validation.ts. El largo individual de cada nombre/apellido/
    // teléfono dentro de `companions` y de cada valor de `customData` NO se
    // valida acá — Firestore Rules no puede iterar los elementos de un
    // array/mapa para exigir una condición por elemento (misma limitación ya
    // documentada arriba en isValidPublicGuestRegistration para customData);
    // esa validación por elemento la hace solo el cliente (ver
    // updateGuestSelf en src/firebase/guests.ts).
    function isValidGuestSelfEdit() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 121
        && (!('lastName' in d) || (d.lastName is string && d.lastName.size() <= 60))
        && d.companions is list
        && d.companions.size() == companionsCountBefore()
        && (!('customData' in d) || (d.customData is map && d.customData.size() <= 30));
    }

    // Tope de dispositivos reconocidos por pase (ver claimGuestPass en
    // src/firebase/guests.ts) — debe coincidir con INDIVIDUAL_DEVICE_CAP/
    // GROUP_DEVICE_CAP ahí. Solo actúa como techo de tamaño del arreglo
    // (defensa en profundidad); la rotación LRU real la hace el cliente.
    function guestDeviceCap(guestData) {
      return guestData.get('isGroup', false) ? 8 : 3;
    }

    // Un pase se considera "sin reclamar todavía" si nunca se guardó
    // `lockTokens` (invitado creado antes de este campo, o que nunca abrió
    // su pase) — mismo criterio permisivo que antes tenía `lockToken ==
    // null`. Una vez reclamado, cualquier dispositivo de la lista puede
    // escribir (RSVP, comprobante de pago, auto-edición) — ya no hace falta
    // ser exactamente EL dispositivo que ganó la primera carrera.
    function guestLockTokensOk(guestData, incomingToken) {
      return !('lockTokens' in guestData) ||
        guestData.lockTokens.size() == 0 ||
        incomingToken in guestData.lockTokens;
    }

    // Cruza con guests/{guestId} (que sí tiene lockTokens) para autorizar la
    // auto-edición de guestContacts (email/phone) del mismo invitado — ese
    // documento no tiene su propia lista de dispositivos.
    function guestSelfEditContactLockOk(eventId, guestId) {
      let guestPath = /databases/$(database)/documents/events/$(eventId)/guests/$(guestId);
      return exists(guestPath) &&
        guestLockTokensOk(get(guestPath).data, request.resource.data.get('lockToken', null));
    }

    // Sin alta pública ni desde la app: la única forma de agregar/quitar un
    // admin es a mano desde la consola de Firebase (que opera con acceso de
    // propietario del proyecto y no pasa por estas reglas). `allow read`
    // solo le permite a cada usuario confirmar si ES admin — no listar ni
    // ver el resto de la colección.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Buzón de feedback (src/pages/Feedback.tsx). Solo el admin puede leer —
    // ni siquiera el propio autor puede releer lo que envió (pedido
    // explícito: "no permitir que usuarios lean comentarios de otros").
    // Los campos gestionados por el admin (status/priority/tags/adminNotes/
    // favorite/read) deben llegar en sus valores por defecto en el create —
    // si no, cualquier cliente podría auto-marcarse "resuelto" o inyectar
    // notas privadas desde el primer envío.
    function isValidFeedbackCreate() {
      let d = request.resource.data;
      return d.subject is string && d.subject.size() > 0 && d.subject.size() <= 100
        && d.message is string && d.message.size() >= 10 && d.message.size() <= 2000
        && d.category in ['suggestion', 'bug', 'comment', 'question', 'inappropriate', 'feature_request', 'other']
        && d.status == 'new' && d.priority == 'normal'
        && d.tags == [] && d.adminNotes == '' && d.favorite == false && d.read == false
        && (
          (request.auth != null && d.userId == request.auth.uid && d.userEmail == null)
          || (request.auth == null && d.userId == null
              && d.userEmail is string && d.userEmail.size() > 0 && d.userEmail.size() <= 120)
        );
    }

    // Cooldown real (server-verificado) solo es posible para usuarios
    // logueados, porque solo ahí request.auth.uid no se puede falsificar.
    // Un envío anónimo no tiene una identidad que las reglas puedan atar a
    // esta clave — se compensa del lado cliente (ver submitFeedback), mismo
    // criterio ya aceptado en este archivo para los votos del muro (abajo).
    function feedbackCooldownOk() {
      let rl = /databases/$(database)/documents/feedbackRateLimits/$(request.auth.uid);
      return !exists(rl) || request.time > get(rl).data.lastAt + duration.value(45, 's');
    }

    match /feedback/{feedbackId} {
      allow read, list: if isAdmin();
      allow create: if isValidFeedbackCreate()
        && (request.auth == null || feedbackCooldownOk());
      allow update, delete: if isAdmin();
    }

    match /feedbackRateLimits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.lastAt == request.time;
    }

    // Reportes de contenido del muro (comentarios/fotos) — src/firebase/moderation.ts.
    // Solo admin puede leer/listar/actualizar, igual que /feedback: el reporte
    // incluye datos del reportador y del reportado que no deben quedar
    // expuestos a nadie más. "Solo usuarios autenticados pueden reportar"
    // (pedido explícito) es lo que permite además el cooldown y el bloqueo de
    // duplicados server-verificados abajo, a diferencia del envío anónimo de
    // feedback que solo puede protegerse "mejor esfuerzo" del lado cliente.
    function reportCooldownOk() {
      let rl = /databases/$(database)/documents/reportRateLimits/$(request.auth.uid);
      return !exists(rl) || request.time > get(rl).data.lastAt + duration.value(20, 's');
    }

    function reportNotDuplicate(contentId) {
      let dd = /databases/$(database)/documents/reportDedup/$(request.auth.uid)/targets/$(contentId);
      return !exists(dd) || request.time > get(dd).data.lastAt + duration.value(24, 'h');
    }

    function isValidReportCreate() {
      let d = request.resource.data;
      return request.auth != null
        && d.reporterUid == request.auth.uid
        && d.eventId is string && d.eventId.size() > 0
        && d.eventName is string && d.eventName.size() <= 200
        && d.contentType in ['comment', 'photo']
        && d.contentId is string && d.contentId.size() > 0
        && d.contentSnapshot is string && d.contentSnapshot.size() <= 1000
        && d.contentAuthorName is string && d.contentAuthorName.size() <= 120
        && d.reporterName is string && d.reporterName.size() <= 120
        && d.reason is string && d.reason.size() >= 10 && d.reason.size() <= 500
        && d.status == 'pending' && d.adminNotes == '' && d.actionHistory == []
        && reportCooldownOk() && reportNotDuplicate(d.contentId);
    }

    match /reports/{reportId} {
      allow read, list: if isAdmin();
      allow create: if isValidReportCreate();
      allow update, delete: if isAdmin();
    }

    match /reportRateLimits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.lastAt == request.time;
    }

    match /reportDedup/{uid}/targets/{contentId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.lastAt == request.time;
      allow delete: if false;
    }

    // Sanciones de moderación (src/firebase/sanctions.ts). El resumen en
    // sanctions/{uid} es lo que consultan estas mismas reglas para bloquear
    // comentarios/fotos de una cuenta sancionada (ver isBanned/commentsBlocked/
    // photosBlocked más abajo) y lo que el propio usuario puede leer para
    // saber por qué está restringido — pero solo el admin puede escribirlo.
    // El historial detallado (para el panel de admin) vive aparte y nunca lo
    // lee la app del usuario sancionado.
    match /sanctions/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();

      match /history/{entryId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // Consultadas desde las reglas del muro/fotos más abajo — siempre detrás
    // de un `request.auth == null || ...` en el punto de llamada (mismo
    // criterio que feedbackCooldownOk arriba), así que estas funciones pueden
    // asumir que request.auth ya existe. Reglas de Firestore no soportan
    // `if`/`else` como statement, solo expresiones booleanas de corto-circuito
    // (`&&`/`||`) — por eso no hay early-return acá, cada función es una sola
    // expresión que evita llamar a get() cuando exists() ya dio false.
    function isBanned(eventId) {
      let path = /databases/$(database)/documents/sanctions/$(request.auth.uid);
      return exists(path) && (
        (('global' in get(path).data) && get(path).data.global.bannedUntil > request.time.toMillis())
        || (('events' in get(path).data) && (eventId in get(path).data.events) && get(path).data.events[eventId].bannedUntil > request.time.toMillis())
      );
    }

    function commentsBlocked(eventId) {
      let path = /databases/$(database)/documents/sanctions/$(request.auth.uid);
      return isBanned(eventId) || (exists(path) && (
        (('global' in get(path).data) && get(path).data.global.commentBanUntil > request.time.toMillis())
        || (('events' in get(path).data) && (eventId in get(path).data.events) && get(path).data.events[eventId].commentBanUntil > request.time.toMillis())
      ));
    }

    function photosBlocked(eventId) {
      let path = /databases/$(database)/documents/sanctions/$(request.auth.uid);
      return isBanned(eventId) || (exists(path) && (
        (('global' in get(path).data) && get(path).data.global.photoBanUntil > request.time.toMillis())
        || (('events' in get(path).data) && (eventId in get(path).data.events) && get(path).data.events[eventId].photoBanUntil > request.time.toMillis())
      ));
    }

    // Bitácora de acciones del admin (AdminDashboard). Solo el admin puede
    // leerla o crear entradas — nunca editarla ni borrarla, para que quede
    // como un registro confiable de qué se hizo y quién lo hizo.
    match /adminAuditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.adminUid == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // El admin puede listar todos los usuarios (AdminDashboard). Cualquier otro usuario
      // logueado solo puede hacer búsquedas puntuales (getUserByEmail usa limit(1)).
      allow list: if isAdmin() || (request.auth != null && request.query.limit <= 1);
      allow write: if request.auth != null && request.auth.uid == userId;

      match /invitations/{invId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Historial de aceptación de Términos/Privacidad (ver src/firebase/legalAcceptance.ts).
      // Mismo criterio que adminAuditLog: solo se puede crear, nunca editar ni borrar,
      // para que quede como un registro confiable de qué versión aceptó cada usuario.
      match /legalAcceptances/{acceptanceId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if request.auth != null && request.auth.uid == userId
          && request.resource.data.acceptedAt == request.time
          && request.resource.data.documents is list;
        allow update, delete: if false;
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId
        && isValidEventPricing() && isValidMaxCompanions() && eventContentCapsOk();
      allow update: if (isOwnerData(resource.data) || isAdmin()) && eventContentCapsOk()
        // Check-in/checkout individual o contador walk-in (Opciones A y C): solo
        // quien tiene el permiso `scanQr` (dueño siempre lo tiene vía canDo),
        // y solo tocando los dos contadores de presencia. checkedInCount
        // (asistencia acumulada) y occupancyCount (ocupación en vivo) pueden
        // cambiar juntos (checkInGuest/walkIn) o solo el segundo (checkOutGuest,
        // un reingreso vía checkInGuest, o walkOut cuando checkedInCount ya
        // está en 0) — por eso se valida cada uno por separado en vez de
        // exigir que ambos cambien a la vez. Antes esta rama solo exigía
        // isOwnerOrCoOrg (cualquier coanfitrión, tuviera o no scanQr) — un
        // coanfitrión con SOLO otro permiso (ej. viewGuestList) podía escribir
        // estos contadores directo a Firestore sin pasar por checkInGuest.
        // 'checkinsByHour' (auditoría F4): checkInGuest suma 1 al bucket de
        // la hora actual en la MISMA escritura — no se valida su delta con
        // counterDeltaOk (es un mapa de a lo sumo 24 claves, sin riesgo de
        // tamaño, y solo alimenta un gráfico informativo en Reports, no
        // ninguna decisión de capacidad/pago).
        || (canDoData(resource.data, 'scanQr', true)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkedInCount', 'occupancyCount', 'checkinsByHour'])
            && counterDeltaOk(request.resource.data.checkedInCount, resource.data.checkedInCount)
            && counterDeltaOk(request.resource.data.occupancyCount, resource.data.occupancyCount))
        // Un co-organizador (no dueño, así que no cae en la primera rama de
        // este `allow update`) necesita poder tocar guestCount/peopleCount/
        // paidCount en estos casos: eliminar un invitado (deleteGuest,
        // decrementa guestCount/peopleCount y también paidCount si ya había
        // pagado), aprobar o revertir un pago (setGuestPaymentStatus, suma o
        // resta paidCount sin tocar guestCount/peopleCount — el invitado ya
        // contaba desde que se registró, pague o no) y cambiar la cantidad
        // de acompañantes de un invitado ya pagado (updateGuest ajusta
        // peopleCount y paidCount por la misma diferencia). También cubre
        // agregar invitados (addGuest/addGuestsBulk, permiso addGuests):
        // guestCount/peopleCount suben ahí de la misma forma. Mismo margen
        // ±50 que counterDeltaOk ya usa para los contadores de presencia
        // arriba, no un exacto ±1: un borrado (o una carga masiva) puede
        // mover un grupo entero de una sola vez. Gateado por CUALQUIERA de
        // los 4 permisos que legítimamente disparan esta escritura (antes
        // solo isOwnerOrCoOrg, sin mirar el permiso puntual) — no se puede
        // exigir uno solo porque addGuest/deleteGuest/confirmPayment/
        // updateGuest son operaciones distintas que comparten este mismo
        // rango de campos.
        || ((canDoData(resource.data, 'addGuests', true) || canDoData(resource.data, 'deleteGuests', true) || canDoData(resource.data, 'confirmPayments', true) || canDoData(resource.data, 'editGuests', true))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guestCount', 'peopleCount', 'paidCount'])
            && counterDeltaOk(request.resource.data.guestCount, resource.data.guestCount)
            && counterDeltaOk(request.resource.data.peopleCount, resource.data.peopleCount)
            && counterDeltaOk(request.resource.data.paidCount, resource.data.paidCount))
        // deleteGuest borra un invitado que puede estar en cualquier
        // combinación de estados (adentro o no, pagado o no) — decrementa
        // guestCount/peopleCount siempre, y ADEMÁS checkedInCount/
        // occupancyCount (si estaba 'checked_in') y/o paidCount (si ya había
        // pagado) en la MISMA escritura al evento. Eso no encaja en ninguna
        // rama de arriba (cada una cubre un subconjunto fijo de campos para
        // una operación puntual) — sin esto, un coanfitrión con deleteGuests
        // (pero sin scanQr/confirmPayments) no podía borrar a un invitado que
        // ya había entrado o pagado: el batch entero (borrado + contadores)
        // se rechazaba. Gateado solo por deleteGuests — borrar ya autoriza
        // deshacer cualquiera de estos efectos derivados del invitado
        // borrado, no hace falta tener además scanQr/confirmPayments (mismo
        // criterio ya usado por counterDeltaOk: es margen de la OPERACIÓN,
        // no un permiso extra por cada campo que decida tocar).
        || (canDoData(resource.data, 'deleteGuests', true)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guestCount', 'peopleCount', 'checkedInCount', 'occupancyCount', 'paidCount'])
            && counterDeltaOk(request.resource.data.guestCount, resource.data.guestCount)
            && counterDeltaOk(request.resource.data.peopleCount, resource.data.peopleCount)
            && counterDeltaOk(request.resource.data.checkedInCount, resource.data.checkedInCount)
            && counterDeltaOk(request.resource.data.occupancyCount, resource.data.occupancyCount)
            && counterDeltaOk(request.resource.data.paidCount, resource.data.paidCount))
        // Botón "Sí, ya pagó" del escáner (confirmPaymentAndCheckIn): check-in
        // + aprobación de pago en una sola escritura, así que toca los 3
        // contadores (checkedInCount/occupancyCount de la rama de arriba +
        // paidCount de la rama de justo arriba) a la vez — ninguna de esas
        // dos ramas sola lo permite. Exige AMBOS permisos (scanQr y
        // confirmPayments) a la vez, igual que ya exige la rama equivalente
        // de `guests/{guestId}` de más abajo — antes esta rama del evento no
        // miraba ningún permiso puntual.
        || (canDoData(resource.data, 'scanQr', true) && canDoData(resource.data, 'confirmPayments', true)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkedInCount', 'occupancyCount', 'paidCount', 'checkinsByHour'])
            && counterDeltaOk(request.resource.data.checkedInCount, resource.data.checkedInCount)
            && counterDeltaOk(request.resource.data.occupancyCount, resource.data.occupancyCount)
            && counterDeltaOk(request.resource.data.paidCount, resource.data.paidCount))
        // Auto-registro público (Opción B, eventos abiertos): anónimo pero de a 1
        // invitación en 1 (guestCount), sumando entre 1 y 21 personas
        // (peopleCount): el invitado más los acompañantes que el organizador le
        // permita traer — el 21 es 1 + GUEST_MAX_COMPANIONS (techo de
        // EventData.maxCompanions, ver src/utils/validation.ts e
        // isValidMaxCompanions arriba; antes decía 10, copiado de una constante
        // GUEST_MAX_PARTY_SIZE que ya no existe, y rechazaba registros legítimos
        // en eventos con maxCompanions entre 10 y 20). eventGuestCountBefore/
        // eventPeopleCountBefore y no resource.data.guestCount/peopleCount a
        // secas: ver el comentario de esas funciones (eventos legacy sin esos
        // campos denegaban el registro entero).
        || (resource.data.entryMode in ['open', 'hybrid']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guestCount', 'peopleCount'])
            && request.resource.data.guestCount == eventGuestCountBefore(resource.data) + 1
            && request.resource.data.peopleCount >= eventPeopleCountBefore(resource.data) + 1
            && request.resource.data.peopleCount <= eventPeopleCountBefore(resource.data) + 21)
        // "Salir del evento": un co-organizador puede quitarse a sí mismo sin
        // pasar por el dueño. Solo puede tocar sus propias 2 entradas
        // (coOrganizersMap/coOrganizerPermissions) y hacerlas desaparecer —
        // no puede afectar invitados, pagos, ni ningún otro campo del evento.
        || (isCoOrganizerData(resource.data)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coOrganizersMap', 'coOrganizerPermissions', 'updatedAt'])
            && !(request.auth.uid in request.resource.data.get('coOrganizersMap', {}))
            && request.auth.uid in resource.data.coOrganizersMap)
        // Administrar co-organizadores (permiso manageCoOrganizers, default
        // false): puede agregar/editar/quitar a OTROS co-organizadores, pero
        // no puede tocar su propia entrada en ninguno de los dos mapas — ni
        // para autoescalarse más permisos ni para autoeliminarse por esta vía
        // (para eso ya está la rama de "salir del evento" de arriba).
        || (isCoOrganizerData(resource.data)
            && coOrgPermData(resource.data, 'manageCoOrganizers', false)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coOrganizersMap', 'coOrganizerPermissions', 'updatedAt'])
            && request.resource.data.get('coOrganizersMap', {}).get(request.auth.uid, null) == resource.data.coOrganizersMap.get(request.auth.uid, null)
            && request.resource.data.get('coOrganizerPermissions', {}).get(request.auth.uid, {}) == resource.data.get('coOrganizerPermissions', {}).get(request.auth.uid, {})
            && request.resource.data.get('coOrganizersMap', {}).size() <= 20);
      allow delete: if isOwnerData(resource.data) || isAdmin();

      match /guests/{guestId} {
        allow read: if canDo(eventId, 'viewGuestList', true) || isAdmin();
        allow delete: if canDo(eventId, 'deleteGuests', true) || isAdmin();
        allow create: if (canDo(eventId, 'addGuests', true) && companionsWithinLimit(eventId, request.resource.data, false))
          || isAdmin()
          || (isOpenEvent(eventId) && isValidPublicGuestRegistration(eventId));
        allow list: if request.query.limit <= 1;
        allow get: if true;
        // Rama del organizador: updateGuest (nombre/apellido/companions/
        // customData/rsvpStatus/lockToken) no restringe campos, igual que
        // antes — solo cambia de qué permiso depende. Check-in/checkout y
        // confirmar pago sí quedan acotados a sus campos exactos, para que
        // un co-organizador con SOLO scanQr (sin editGuests) pueda escanear,
        // y uno con SOLO confirmPayments pueda aprobar pagos, sin heredar
        // acceso al resto del invitado. companionsWithinLimit (grandfathered)
        // es la única rama de `update` que valida el tope de acompañantes —
        // es la única que puede tocar `companions` desde el organizador.
        //
        // canDoData/companionsWithinLimitData (vía eventDataFor, ver esa
        // función más arriba) en vez de canDo(eventId,...): cada canDo()
        // internamente hace su propio isOwner+isCoOrganizer+coOrgPerm, 3
        // get()s encadenados por llamada. Antes de este cambio, checkInGuest/
        // confirmPaymentAndCheckIn (transacciones que escriben a la vez
        // guests/{guestId} Y events/{eventId}) llegaron a rechazarse con
        // "maximum of 1000 expressions to evaluate" al sumar el costo de
        // evaluar ESTA regla (hasta 6 llamadas a canDo()) más el de
        // events/{eventId} en la misma transacción — mismo incidente ya
        // documentado y resuelto ahí (ver isOwnerData/canDoData más arriba),
        // ahora resuelto acá con el mismo patrón.
        allow update: if (canDoData(eventDataFor(eventId), 'editGuests', true) && companionsWithinLimitData(eventDataFor(eventId), request.resource.data, true)) || isAdmin() ||
          (
            canDoData(eventDataFor(eventId), 'scanQr', true) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'checkedInAt', 'checkedInBy', 'checkedInByEmail', 'checkedOutAt', 'checkedOutByEmail', 'exitType'])
          ) ||
          (
            canDoData(eventDataFor(eventId), 'confirmPayments', true) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentMethod'])
          ) ||
          // Botón "Sí, ya pagó" del escáner (confirmPaymentAndCheckIn): marca
          // el pago Y registra el check-in en una sola escritura, así que
          // necesita AMBOS permisos a la vez (no alcanza con tener solo uno,
          // a diferencia de las dos ramas de arriba) y toca la unión exacta
          // de los dos grupos de campos.
          (
            canDoData(eventDataFor(eventId), 'scanQr', true) && canDoData(eventDataFor(eventId), 'confirmPayments', true) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'checkedInAt', 'checkedInBy', 'checkedInByEmail', 'checkedOutAt', 'checkedOutByEmail', 'exitType', 'paymentStatus', 'paymentMethod'])
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpStatus', 'lockToken']) &&
            guestLockTokensOk(resource.data, request.resource.data.lockToken)
          ) ||
          // El propio invitado marca "ya pagué / comprobante enviado"
          // (submitPaymentProof, src/firebase/guests.ts) — solo desde un
          // dispositivo ya reconocido (mismo chequeo de lockTokens que
          // rsvpStatus arriba), solo para transferencia. Sin límite de
          // tiempo (ya no existe el apartado temporal/cronómetro): puede
          // mandarlo cuando quiera mientras no esté ya pagado ni ya tenga un
          // comprobante en revisión. `!= 'paid' && != 'pending_confirmation'`
          // (en vez de enumerar 'unpaid'/'expired') para que un invitado
          // legacy con el valor 'expired' (escrito por el barrido de
          // reservas que este proyecto ya no usa) también pueda mandar su
          // comprobante, igual que cualquier invitado sin pagar — no hace
          // falta migrar esos documentos viejos. paymentNote (número de
          // referencia) sigue siendo OBLIGATORIO — pedido explícito: sin una
          // referencia concreta, el organizador no tiene nada que cotejar
          // contra su resumen bancario para aprobar/rechazar.
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'paymentNote']) &&
            guestLockTokensOk(resource.data, request.resource.data.get('lockToken', null)) &&
            resource.data.paymentMethod == 'transfer' &&
            resource.data.paymentStatus != 'paid' &&
            resource.data.paymentStatus != 'pending_confirmation' &&
            request.resource.data.paymentStatus == 'pending_confirmation' &&
            request.resource.data.paymentNote is string &&
            request.resource.data.paymentNote.size() > 0 &&
            request.resource.data.paymentNote.size() <= 300
          ) ||
          // El propio invitado edita su información de registro (GuestPass,
          // "Editar mis datos") — mismo gate de lockTokens que las dos ramas
          // de arriba. qrToken/status/checkedIn*/paymentStatus/etc. quedan
          // FUERA de este hasOnly a propósito: si un intento de escritura
          // toca cualquiera de esos campos junto con estos, cae toda la
          // rama (no solo esos campos).
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'lastName', 'companions', 'customData', 'lockToken']) &&
            guestLockTokensOk(resource.data, request.resource.data.lockToken) &&
            isValidGuestSelfEdit()
          ) ||
          // claimGuestPass (src/firebase/guests.ts): reconoce un dispositivo
          // nuevo agregándolo a `lockTokens` (o inicializándola). Cualquiera
          // puede sumarse a la lista — así es como se "reclama" el pase la
          // primera vez, igual que antes con lockToken == null — siempre que
          // el resultado sea una lista dentro del tope (guestDeviceCap) y el
          // espejo `lockToken` coincida con el último elemento agregado. No
          // valida acá que la rotación LRU de dispositivos viejos sea exacta
          // (eso lo hace el cliente): esta escritura solo habilita al invitado
          // a operar SU PROPIO pase, no afecta check-in, pagos aprobados por
          // el organizador ni a otros invitados.
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lockToken', 'lockTokens']) &&
            request.resource.data.lockTokens is list &&
            request.resource.data.lockTokens.size() > 0 &&
            request.resource.data.lockTokens.size() <= guestDeviceCap(resource.data) &&
            request.resource.data.lockToken == request.resource.data.lockTokens[request.resource.data.lockTokens.size() - 1]
          );
      }

      // email/phone del invitado: antes nunca público. Ahora `get` por id
      // conocido es público — mismo modelo de confianza que ya tiene
      // guests/{guestId} (`allow get: if true`): quien tiene el link /pass
      // ya puede leer el resto del invitado. `list`/búsqueda sigue vedada al
      // público — nadie puede enumerar la colección ni buscar por campo,
      // solo pedir el contacto de un guestId puntual ya resuelto vía
      // guests/{guestId}.
      match /guestContacts/{guestId} {
        allow get: if true;
        allow list: if canDo(eventId, 'viewGuestList', true) || isAdmin();
        allow delete: if canDo(eventId, 'deleteGuests', true) || isAdmin();
        // canDo(...,'addGuests',...) además de editGuests: agregar un
        // invitado (addGuest/addGuestsBulk/import CSV) puede incluir su
        // teléfono/email en la MISMA operación de alta — antes, un
        // coanfitrión con addGuests:true pero editGuests:false (combinación
        // válida, ej. "solo puede sumar invitados nuevos") no podía guardar
        // ese contacto: el guest se creaba pero el batch entero fallaba en
        // el `set` de guestContacts, dejando el teléfono/email perdido.
        allow create: if canDo(eventId, 'editGuests', true) || canDo(eventId, 'addGuests', true) || isAdmin()
          || (isOpenEvent(eventId) && isValidPublicGuestContact())
          // Primer guardado de contacto del propio invitado (p.ej. un
          // invitado de lista, agregado sin teléfono, que ahora carga el
          // suyo por primera vez) — a diferencia de la rama de arriba, no
          // exige isOpenEvent: esto aplica a cualquier invitado con pase,
          // venga de lista o autoregistro.
          || (
            request.resource.data.keys().hasOnly(['email', 'phone', 'lockToken']) &&
            isValidPublicGuestContact() &&
            guestSelfEditContactLockOk(eventId, guestId)
          );
        allow update: if canDo(eventId, 'editGuests', true) || isAdmin()
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email', 'phone', 'lockToken']) &&
            isValidPublicGuestContact() &&
            guestSelfEditContactLockOk(eventId, guestId)
          );
      }

      match /checkins/{checkinId} {
        // También lo lee Reports (viewReports) — no solo el escáner.
        allow read: if canDo(eventId, 'scanQr', true) || canDo(eventId, 'viewReports', true) || isAdmin();
        allow create: if canDo(eventId, 'scanQr', true) || isAdmin();
        allow delete: if isOwner(eventId) || isAdmin();
        allow update: if false;
      }

      // Funcionalidad eliminada (ver src/firebase/waitlist.ts, borrado). Ya
      // no hay ningún camino en la app que lleve a un invitado a esperar
      // cupo — el registro nunca se bloquea — así que no debe quedar
      // ninguna forma de escribir acá, ni siquiera hablando directo contra
      // Firestore. Entries viejas de antes de este cambio pueden seguir
      // existiendo (huérfanas, invisibles) — no hace falta borrarlas, y esta
      // regla no las afecta retroactivamente.
      match /waitlist/{entryId} {
        allow read, write: if false;
      }

      match /wall/{messageId} {
        allow read: if true;
        // Sancionado (baneo o restricción de comentarios, global o de este
        // evento en particular) → bloqueado server-side, no solo en la UI.
        // Un invitado sin sesión no pasa por este chequeo (no hay uid que
        // sancionar) — mismo límite que el resto de las protecciones
        // anti-abuso de este archivo para tráfico anónimo.
        allow create: if isValidWallMessage(eventId) && (request.auth == null || !commentsBlocked(eventId));
        // TODO Fase 3+: esta rama sigue sin verificar que la key agregada
        // corresponda a una identidad real (ver isSingleReactionKeyChange
        // más arriba — las reacciones son anónimas, no hay nada del lado
        // servidor con qué comparar). Sí evita, desde ahora, que UN solo
        // request inyecte muchas claves de golpe (isSingleReactionKeyChange)
        // y que el mapa supere el tope de tamaño (reactions.size()). Un
        // cierre completo del gap de identidad requeriría mover la reacción
        // a una subcolección wall/{id}/reactions/{token} con un doc por
        // reactor. Mismo criterio, sin resolver todavía, en la rama de
        // reacciones de `photos` de más abajo (reutiliza este mismo patrón).
        allow update: if canDo(eventId, 'moderateWall', true) || isAdmin()
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              && request.resource.data.reactions.size() <= 5000
              && isSingleReactionKeyChange(resource.data.get('reactions', {}), request.resource.data.reactions))
          // Responder: mismo criterio de autorización que crear un mensaje
          // (ver isValidWallReplyAppend) — el anfitrión y cualquier invitado
          // no sancionado usan esta misma rama, no hay una ruta aparte.
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
              && isValidWallReplyAppend(eventId))
          // Borrar el propio mensaje (deleteWallMessage hace un soft-delete
          // vía update, `deleted: true` — no un `delete` real). Solo se
          // puede verificar para un autor CON SESIÓN cuyo `authorToken`
          // quedó igual a su uid al postear (ver `authorToken` en
          // EventWall.tsx) — un invitado sin cuenta no tiene ninguna
          // identidad que estas reglas puedan comprobar del lado servidor,
          // así que no puede autoborrarse acá (mismo límite ya documentado
          // arriba para authorRole/postWall). Solo permite marcar `deleted`,
          // y solo a `true` (no "revivir" un mensaje ya borrado por esta
          // vía).
          || (request.auth != null && request.auth.uid == resource.data.authorToken
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted'])
              && request.resource.data.deleted == true);
        allow delete: if canDo(eventId, 'moderateWall', true) || isAdmin();
      }

      // Álbum de fotos del evento. Visible para cualquiera que conozca el
      // eventId (mismo criterio que el muro y el pase del invitado).
      // Solo puede subir fotos quien tenga un qrToken válido (campo que se
      // escribe en el doc) — el organizador/co-org puede borrar cualquier foto.
      match /photos/{photoId} {
        allow read: if true;
        allow create: if request.resource.data.url is string
          && request.resource.data.url.size() > 0
          && request.resource.data.url.size() <= 500
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 60
          && request.resource.data.authorToken is string
          && request.resource.data.authorToken.size() > 0
          && request.resource.data.authorToken.size() <= 100
          && (!('caption' in request.resource.data)
              || (request.resource.data.caption is string
                  && request.resource.data.caption.size() <= 120))
          && (request.auth == null || !photosBlocked(eventId));
        // Destacar/quitar destacado (mismo concepto que pinWallMessage del
        // muro) — el bypass de organizador/admin sigue acotado solo a este
        // campo, para que esta apertura no habilite editar url/authorName/
        // etc. de una foto ya subida (a diferencia de `wall`, donde
        // isOwnerOrCoOrg/isAdmin puede tocar cualquier campo — acá se
        // mantiene la postura más restrictiva que ya tenía `photos`).
        //
        // Reacciones y respuestas (fotos Y las "historias", que son las
        // mismas fotos vistas agrupadas por autor — ver StoriesBar.tsx)
        // reutilizan exactamente las mismas dos ramas que ya validaban esto
        // para `wall`: mismo campo `reactions` con el mismo tope y el mismo
        // isSingleReactionKeyChange, mismo isValidWallReplyAppend para
        // `replies`. Ver ese TODO Fase 3+ más arriba — el mismo gap de
        // identidad (no de tamaño) aplica acá.
        allow update: if ((canDo(eventId, 'moderateWall', true) || isAdmin())
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned'])
              && request.resource.data.pinned is bool)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              && request.resource.data.reactions.size() <= 5000
              && isSingleReactionKeyChange(resource.data.get('reactions', {}), request.resource.data.reactions))
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
              && isValidWallReplyAppend(eventId));
        allow delete: if canDo(eventId, 'moderateWall', true) || isAdmin();
      }
    }
  }
}
