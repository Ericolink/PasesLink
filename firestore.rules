rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(eventId) {
      return request.auth != null &&
        request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.ownerId;
    }

    function isCoOrganizer(eventId) {
      let ev = get(/databases/$(database)/documents/events/$(eventId));
      return request.auth != null &&
        ev.data.coOrganizersMap != null &&
        request.auth.uid in ev.data.coOrganizersMap;
    }

    function isOwnerOrCoOrg(eventId) {
      return isOwner(eventId) || isCoOrganizer(eventId);
    }

    // Admin = tener un documento propio en /admins/{uid}. Se eligió esta
    // colección en vez de customClaims (Fase 4D) porque asignar customClaims
    // requiere el Admin SDK, que en este proyecto solo está disponible vía
    // Cloud Functions — y este proyecto está deliberadamente en el plan
    // Spark (gratis), sin Blaze. Agregar/quitar admins se hace a mano desde
    // la consola de Firebase (Firestore → admins), nunca desde la app: ver
    // `allow write: if false` en el match de abajo.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOpenEvent(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data.entryMode in ['open', 'hybrid'];
    }

    // Valida el delta de un contador de "gente adentro" (checkedInCount /
    // occupancyCount): sin cambios, o +-1..50 en cualquier dirección —
    // walkIn/walkOut mueven de a 1 (Opción A/C, sin acompañantes), mientras
    // que checkInGuest/checkOutGuest mueven partySize() (invitado +
    // acompañantes) de una sola vez, en cualquiera de los dos sentidos según
    // sea una entrada o una salida. El tope de 50 no se ata a un límite
    // exacto de acompañantes que la UI no impone.
    function counterDeltaOk(newVal, oldVal) {
      return newVal == oldVal
        || (newVal < oldVal && newVal >= oldVal - 50)
        || (newVal > oldVal && newVal <= oldVal + 50);
    }

    // Cualquier cliente puede crear wall/waitlist sin autenticarse — estos
    // límites son la última barrera real si alguien evita por completo la
    // capa de aplicación (src/firebase/wall.ts, src/firebase/waitlist.ts) y
    // escribe directo contra Firestore. Deben coincidir con src/utils/validation.ts.
    function isValidWallMessage() {
      let d = request.resource.data;
      return d.text is string && d.text.size() > 0 && d.text.size() <= 500
        && d.type in ['comment', 'question', 'music', 'idea']
        && d.authorName is string && d.authorName.size() > 0 && d.authorName.size() <= 60
        && d.authorToken is string && d.authorToken.size() <= 100;
    }

    // Misma validación que isValidWallMessage, para el elemento agregado al
    // array `replies` (ver isValidWallReplyAppend más abajo). authorRole no
    // se restringe a 'guest' — el anfitrión responde con este mismo flujo,
    // no uno aparte.
    function isValidWallReply(r) {
      return r.text is string && r.text.size() > 0 && r.text.size() <= 500
        && r.authorName is string && r.authorName.size() > 0 && r.authorName.size() <= 60
        && r.authorToken is string && r.authorToken.size() <= 100
        && r.authorRole in ['owner', 'guest'];
    }

    // Cualquier participante autorizado del muro puede agregar una respuesta
    // (misma autorización que crear un mensaje nuevo: no bloqueado por
    // sanción). Solo permite AGREGAR un elemento al final del array —
    // request.resource.data.replies[0:N] == resource.data.replies exige que
    // las respuestas ya existentes lleguen sin tocar, para que un cliente no
    // pueda reescribir o borrar respuestas ajenas aprovechando este permiso.
    function isValidWallReplyAppend(eventId) {
      let oldReplies = resource.data.replies;
      let newReplies = request.resource.data.replies;
      return (request.auth == null || !commentsBlocked(eventId))
        && newReplies.size() == oldReplies.size() + 1
        && newReplies.size() <= 500
        && newReplies[0:oldReplies.size()] == oldReplies
        && isValidWallReply(newReplies[oldReplies.size()]);
    }

    function isValidWaitlistEntry() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 60
        && d.lastName is string && d.lastName.size() > 0 && d.lastName.size() <= 60
        && d.phone is string && d.phone.size() <= 30;
    }

    // Auto-registro público de invitados (registerWalkInGuest, eventos
    // open/hybrid). Solo se valida esta rama pública — el alta hecha por el
    // organizador (addGuest/addGuestsBulk) no pasa por isOpenEvent y queda
    // fuera de esta validación, sin cambiar su comportamiento actual.
    // customData.size() limita la CANTIDAD de campos (Firestore rules no
    // puede iterar un mapa para validar el largo de cada valor individual —
    // eso solo lo cubren la UI y src/firebase/capacity.ts). Límites deben
    // coincidir con src/utils/validation.ts.
    function isValidPublicGuestRegistration() {
      let d = request.resource.data;
      return d.name is string && d.name.size() > 0 && d.name.size() <= 121
        && (!('customData' in d) || (d.customData is map && d.customData.size() <= 30));
    }

    function isValidPublicGuestContact() {
      let d = request.resource.data;
      return (!('email' in d) || (d.email is string && d.email.size() <= 120))
        && (!('phone' in d) || (d.phone is string && d.phone.size() <= 30));
    }

    // Sin alta pública ni desde la app: la única forma de agregar/quitar un
    // admin es a mano desde la consola de Firebase (que opera con acceso de
    // propietario del proyecto y no pasa por estas reglas). `allow read`
    // solo le permite a cada usuario confirmar si ES admin — no listar ni
    // ver el resto de la colección.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Buzón de feedback (src/pages/Feedback.tsx). Solo el admin puede leer —
    // ni siquiera el propio autor puede releer lo que envió (pedido
    // explícito: "no permitir que usuarios lean comentarios de otros").
    // Los campos gestionados por el admin (status/priority/tags/adminNotes/
    // favorite/read) deben llegar en sus valores por defecto en el create —
    // si no, cualquier cliente podría auto-marcarse "resuelto" o inyectar
    // notas privadas desde el primer envío.
    function isValidFeedbackCreate() {
      let d = request.resource.data;
      return d.subject is string && d.subject.size() > 0 && d.subject.size() <= 100
        && d.message is string && d.message.size() >= 10 && d.message.size() <= 2000
        && d.category in ['suggestion', 'bug', 'comment', 'question', 'inappropriate', 'feature_request', 'other']
        && d.status == 'new' && d.priority == 'normal'
        && d.tags == [] && d.adminNotes == '' && d.favorite == false && d.read == false
        && (
          (request.auth != null && d.userId == request.auth.uid && d.userEmail == null)
          || (request.auth == null && d.userId == null
              && d.userEmail is string && d.userEmail.size() > 0 && d.userEmail.size() <= 120)
        );
    }

    // Cooldown real (server-verificado) solo es posible para usuarios
    // logueados, porque solo ahí request.auth.uid no se puede falsificar.
    // Un envío anónimo no tiene una identidad que las reglas puedan atar a
    // esta clave — se compensa del lado cliente (ver submitFeedback), mismo
    // criterio ya aceptado en este archivo para los votos del muro (abajo).
    function feedbackCooldownOk() {
      let rl = /databases/$(database)/documents/feedbackRateLimits/$(request.auth.uid);
      return !exists(rl) || request.time > get(rl).data.lastAt + duration.value(45, 's');
    }

    match /feedback/{feedbackId} {
      allow read, list: if isAdmin();
      allow create: if isValidFeedbackCreate()
        && (request.auth == null || feedbackCooldownOk());
      allow update, delete: if isAdmin();
    }

    match /feedbackRateLimits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.lastAt == request.time;
    }

    // Reportes de contenido del muro (comentarios/fotos) — src/firebase/moderation.ts.
    // Solo admin puede leer/listar/actualizar, igual que /feedback: el reporte
    // incluye datos del reportador y del reportado que no deben quedar
    // expuestos a nadie más. "Solo usuarios autenticados pueden reportar"
    // (pedido explícito) es lo que permite además el cooldown y el bloqueo de
    // duplicados server-verificados abajo, a diferencia del envío anónimo de
    // feedback que solo puede protegerse "mejor esfuerzo" del lado cliente.
    function reportCooldownOk() {
      let rl = /databases/$(database)/documents/reportRateLimits/$(request.auth.uid);
      return !exists(rl) || request.time > get(rl).data.lastAt + duration.value(20, 's');
    }

    function reportNotDuplicate(contentId) {
      let dd = /databases/$(database)/documents/reportDedup/$(request.auth.uid)/targets/$(contentId);
      return !exists(dd) || request.time > get(dd).data.lastAt + duration.value(24, 'h');
    }

    function isValidReportCreate() {
      let d = request.resource.data;
      return request.auth != null
        && d.reporterUid == request.auth.uid
        && d.eventId is string && d.eventId.size() > 0
        && d.eventName is string && d.eventName.size() <= 200
        && d.contentType in ['comment', 'photo']
        && d.contentId is string && d.contentId.size() > 0
        && d.contentSnapshot is string && d.contentSnapshot.size() <= 1000
        && d.contentAuthorName is string && d.contentAuthorName.size() <= 120
        && d.reporterName is string && d.reporterName.size() <= 120
        && d.reason is string && d.reason.size() >= 10 && d.reason.size() <= 500
        && d.status == 'pending' && d.adminNotes == '' && d.actionHistory == []
        && reportCooldownOk() && reportNotDuplicate(d.contentId);
    }

    match /reports/{reportId} {
      allow read, list: if isAdmin();
      allow create: if isValidReportCreate();
      allow update, delete: if isAdmin();
    }

    match /reportRateLimits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.lastAt == request.time;
    }

    match /reportDedup/{uid}/targets/{contentId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.lastAt == request.time;
      allow delete: if false;
    }

    // Sanciones de moderación (src/firebase/sanctions.ts). El resumen en
    // sanctions/{uid} es lo que consultan estas mismas reglas para bloquear
    // comentarios/fotos de una cuenta sancionada (ver isBanned/commentsBlocked/
    // photosBlocked más abajo) y lo que el propio usuario puede leer para
    // saber por qué está restringido — pero solo el admin puede escribirlo.
    // El historial detallado (para el panel de admin) vive aparte y nunca lo
    // lee la app del usuario sancionado.
    match /sanctions/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();

      match /history/{entryId} {
        allow read, create: if isAdmin();
        allow update, delete: if false;
      }
    }

    // Consultadas desde las reglas del muro/fotos más abajo — siempre detrás
    // de un `request.auth == null || ...` en el punto de llamada (mismo
    // criterio que feedbackCooldownOk arriba), así que estas funciones pueden
    // asumir que request.auth ya existe. Reglas de Firestore no soportan
    // `if`/`else` como statement, solo expresiones booleanas de corto-circuito
    // (`&&`/`||`) — por eso no hay early-return acá, cada función es una sola
    // expresión que evita llamar a get() cuando exists() ya dio false.
    function isBanned(eventId) {
      let path = /databases/$(database)/documents/sanctions/$(request.auth.uid);
      return exists(path) && (
        (('global' in get(path).data) && get(path).data.global.bannedUntil > request.time.toMillis())
        || (('events' in get(path).data) && (eventId in get(path).data.events) && get(path).data.events[eventId].bannedUntil > request.time.toMillis())
      );
    }

    function commentsBlocked(eventId) {
      let path = /databases/$(database)/documents/sanctions/$(request.auth.uid);
      return isBanned(eventId) || (exists(path) && (
        (('global' in get(path).data) && get(path).data.global.commentBanUntil > request.time.toMillis())
        || (('events' in get(path).data) && (eventId in get(path).data.events) && get(path).data.events[eventId].commentBanUntil > request.time.toMillis())
      ));
    }

    function photosBlocked(eventId) {
      let path = /databases/$(database)/documents/sanctions/$(request.auth.uid);
      return isBanned(eventId) || (exists(path) && (
        (('global' in get(path).data) && get(path).data.global.photoBanUntil > request.time.toMillis())
        || (('events' in get(path).data) && (eventId in get(path).data.events) && get(path).data.events[eventId].photoBanUntil > request.time.toMillis())
      ));
    }

    // Bitácora de acciones del admin (AdminDashboard). Solo el admin puede
    // leerla o crear entradas — nunca editarla ni borrarla, para que quede
    // como un registro confiable de qué se hizo y quién lo hizo.
    match /adminAuditLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.adminUid == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // El admin puede listar todos los usuarios (AdminDashboard). Cualquier otro usuario
      // logueado solo puede hacer búsquedas puntuales (getUserByEmail usa limit(1)).
      allow list: if isAdmin() || (request.auth != null && request.query.limit <= 1);
      allow write: if request.auth != null && request.auth.uid == userId;

      match /invitations/{invId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if isOwner(eventId) || isAdmin()
        // Check-in/checkout individual o contador walk-in (Opciones A y C): solo
        // organizador/co-org, y solo tocando los dos contadores de presencia.
        // checkedInCount (asistencia acumulada) y occupancyCount (ocupación en
        // vivo) pueden cambiar juntos (checkInGuest/walkIn) o solo el segundo
        // (checkOutGuest, un reingreso vía checkInGuest, o walkOut cuando
        // checkedInCount ya está en 0) — por eso se valida cada uno por
        // separado en vez de exigir que ambos cambien a la vez.
        || (isOwnerOrCoOrg(eventId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkedInCount', 'occupancyCount'])
            && counterDeltaOk(request.resource.data.checkedInCount, resource.data.checkedInCount)
            && counterDeltaOk(request.resource.data.occupancyCount, resource.data.occupancyCount))
        // Auto-registro público (Opción B, eventos abiertos): anónimo pero de a 1
        // invitación en 1 (guestCount), sumando entre 1 y GUEST_MAX_PARTY_SIZE
        // personas (peopleCount) — ese invitado puede traer acompañantes (ver
        // GUEST_MAX_PARTY_SIZE en src/utils/validation.ts, debe coincidir con
        // el 10 de acá).
        || (resource.data.entryMode in ['open', 'hybrid']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guestCount', 'peopleCount'])
            && request.resource.data.guestCount == resource.data.guestCount + 1
            && request.resource.data.peopleCount >= resource.data.peopleCount + 1
            && request.resource.data.peopleCount <= resource.data.peopleCount + 10);
      allow delete: if isOwner(eventId) || isAdmin();

      match /guests/{guestId} {
        allow read, delete: if isOwnerOrCoOrg(eventId) || isAdmin();
        allow create: if isOwnerOrCoOrg(eventId) || isAdmin()
          || (isOpenEvent(eventId) && isValidPublicGuestRegistration());
        allow list: if request.query.limit <= 1;
        allow get: if true;
        allow update: if isOwnerOrCoOrg(eventId) || isAdmin() ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvpStatus', 'lockToken']) &&
            (resource.data.lockToken == null || resource.data.lockToken == request.resource.data.lockToken)
          );
      }

      // email/phone del invitado: nunca público. A diferencia de `guests`
      // (que necesita `allow get: if true` para que el pase compartible
      // funcione sin login), esta colección solo la lee el organizador.
      match /guestContacts/{guestId} {
        allow read, delete: if isOwnerOrCoOrg(eventId) || isAdmin();
        allow create: if isOwnerOrCoOrg(eventId) || isAdmin()
          || (isOpenEvent(eventId) && isValidPublicGuestContact());
        allow update: if isOwnerOrCoOrg(eventId) || isAdmin();
      }

      match /checkins/{checkinId} {
        allow read: if isOwnerOrCoOrg(eventId) || isAdmin();
        allow create: if isOwnerOrCoOrg(eventId) || isAdmin();
        allow delete: if isOwner(eventId) || isAdmin();
        allow update: if false;
      }

      match /waitlist/{entryId} {
        allow read, update, delete: if isOwner(eventId) || isAdmin();
        allow create: if isValidWaitlistEntry();
      }

      match /wall/{messageId} {
        allow read: if true;
        // Sancionado (baneo o restricción de comentarios, global o de este
        // evento en particular) → bloqueado server-side, no solo en la UI.
        // Un invitado sin sesión no pasa por este chequeo (no hay uid que
        // sancionar) — mismo límite que el resto de las protecciones
        // anti-abuso de este archivo para tráfico anónimo.
        allow create: if isValidWallMessage() && (request.auth == null || !commentsBlocked(eventId));
        // TODO Fase 3+: esta rama no verifica que la key agregada/quitada en
        // `reactions` sea el propio token del dispositivo que hace la
        // petición — solo limita qué campo se toca y el tamaño máximo del
        // mapa. Un cliente que hable directo con Firestore (evitando
        // src/firebase/wall.ts) puede reaccionar repetidamente simulando
        // tokens distintos. Solución robusta: mover la reacción a una
        // subcolección wall/{id}/reactions/{token} con un doc por reactor.
        allow update: if isOwnerOrCoOrg(eventId) || isAdmin()
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
              && request.resource.data.reactions.size() <= 5000)
          // Responder: mismo criterio de autorización que crear un mensaje
          // (ver isValidWallReplyAppend) — el anfitrión y cualquier invitado
          // no sancionado usan esta misma rama, no hay una ruta aparte.
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replies'])
              && isValidWallReplyAppend(eventId));
        allow delete: if isOwnerOrCoOrg(eventId) || isAdmin();
      }

      // Álbum de fotos del evento. Visible para cualquiera que conozca el
      // eventId (mismo criterio que el muro y el pase del invitado).
      // Solo puede subir fotos quien tenga un qrToken válido (campo que se
      // escribe en el doc) — el organizador/co-org puede borrar cualquier foto.
      match /photos/{photoId} {
        allow read: if true;
        allow create: if request.resource.data.url is string
          && request.resource.data.url.size() > 0
          && request.resource.data.url.size() <= 500
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 60
          && request.resource.data.authorToken is string
          && request.resource.data.authorToken.size() > 0
          && request.resource.data.authorToken.size() <= 100
          && (!('caption' in request.resource.data)
              || (request.resource.data.caption is string
                  && request.resource.data.caption.size() <= 120))
          && (request.auth == null || !photosBlocked(eventId));
        // Destacar/quitar destacado (mismo concepto que pinWallMessage del
        // muro) — único update permitido, y solo ese campo, para que esta
        // apertura no habilite editar url/authorName/etc. de una foto ya subida.
        allow update: if (isOwnerOrCoOrg(eventId) || isAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned'])
          && request.resource.data.pinned is bool;
        allow delete: if isOwnerOrCoOrg(eventId) || isAdmin();
      }
    }
  }
}
